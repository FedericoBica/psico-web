generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

model Category {
  id      String    @id @default(uuid())
  name    String    @unique
  Product Product[]
}

model Product {
  id           String   @id @default(uuid())
  title        String
  description  String
  price        Float    @default(0)
  oldPrice     Float?
  slug         String   @unique
  tags         String[] @default([])
  downloadUrl  String
  isPublished  Boolean  @default(true)

  // Libro físico
  hasPhysical   Boolean @default(false)
  physicalPrice Float?

  // Relaciones
  category     Category       @relation(fields: [categoryId], references: [id])
  categoryId   String
  ProductImage ProductImage[]
  OrderItem    OrderItem[]

  @@index([categoryId])
}

model ProductImage {
  id  Int    @id @default(autoincrement())
  url String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          Role      @default(user)
  image         String?

  Order Order[]
}

model Order {
  id           String    @id @default(uuid())
  subTotal     Float
  total        Float
  itemsInOrder Int
  isPaid       Boolean   @default(false)
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  buyerEmail String?

  // Datos de envío para libros físicos
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingDept    String?

  OrderItem     OrderItem[]
  transactionId String?
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float
  format   String @default("digital")  // "digital" | "physical"

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}

model Coupon {
  id         String    @id @default(uuid())
  code       String    @unique
  discount   Int
  isActive   Boolean   @default(true)
  validUntil DateTime?
  createdAt  DateTime  @default(now())
}

model Post {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  image       String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StoreConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}